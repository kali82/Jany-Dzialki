# Brevo API example. In Render/Replit, put these values in Secrets instead of .env.
BREVO_API_KEY=your-brevo-api-key

# Where contact form messages should arrive.
CONTACT_TO=your-address@gmail.com

# Must be a sender approved in Brevo.
CONTACT_FROM="Formularz Jany Dzialki <your-approved-sender@example.com>"
