# Gmail SMTP example. In Replit, put these values in Secrets instead of .env.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-gmail-app-password

# Where contact form messages should arrive.
CONTACT_TO=your-address@gmail.com

# Optional. For Gmail this should usually use the same address as SMTP_USER.
CONTACT_FROM="Formularz Jany Dzialki <your-address@gmail.com>"
